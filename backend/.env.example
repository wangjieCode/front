# ============================================
# Web 前端实习生助手系统 - 环境配置
# ============================================

# --------------------------------------------
# 服务器配置
# --------------------------------------------
PORT=3001
NODE_ENV=development

# --------------------------------------------
# 数据库配置
# --------------------------------------------
# Supabase PostgreSQL 连接字符串
# 格式: postgresql://[user]:[password]@[host]:[port]/[database]
# 本地开发: postgresql://postgres:your_password@localhost:5432/conversation_db
# Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/conversation_db

# --------------------------------------------
# 运行模式
# --------------------------------------------
# 'local' - 在本机运行（推荐用于开发和测试）
# 'remote' - 使用远程虚拟机（生产环境）
RUN_MODE=local

# --------------------------------------------
# 本机模式配置（RUN_MODE=local）
# --------------------------------------------
# Git 仓库的工作目录（本机路径）
# 相对路径：./workspace（将在项目根目录创建）
# 绝对路径：/Users/username/projects/my-project
GIT_WORK_DIR=../workspace/front-workspace/dtmall-admin

# Git 默认分支（通常是 main 或 master）
GIT_DEFAULT_BRANCH=master

# --------------------------------------------
# 远程模式配置（RUN_MODE=remote）
# 仅在 RUN_MODE=remote 时需要配置
# --------------------------------------------
# 虚拟机的 IP 地址或域名
# SSH_HOST=your-vm-host

# SSH 端口（默认 22）
# SSH_PORT=22

# SSH 用户名
# SSH_USERNAME=your-username

# SSH 私钥文件路径（绝对路径）
# 例如：/Users/username/.ssh/id_rsa 或 /home/username/.ssh/id_rsa
# SSH_PRIVATE_KEY_PATH=/path/to/your/private/key

# Git 仓库的工作目录（虚拟机上的路径）
# 例如：/home/user/projects/my-frontend-project
# GIT_WORK_DIR=/path/to/git/repo

# --------------------------------------------
# GitLab 配置
# --------------------------------------------
# GitLab 实例 URL
# 公共 GitLab: https://gitlab.com
# 私有实例: https://gitlab.your-company.com
GITLAB_URL=https://gitlab.com

# GitLab Personal Access Token
# 需要权限：api, read_repository, write_repository
# 创建方式：GitLab > Settings > Access Tokens
GITLAB_TOKEN=your-gitlab-personal-access-token

# GitLab 项目 ID
# 可以在项目页面的 Settings > General 中找到
GITLAB_PROJECT_ID=your-project-id

# --------------------------------------------
# 代码工具配置
# --------------------------------------------
# 代码工具类型: qodercli, neovate, cursor, copilot
# 推荐使用 neovate（默认）
CODE_TOOL_TYPE=neovate

# neovate 配置
# IFLOW API Key（必需）
# 获取方式：联系管理员或访问 iflow 平台
IFLOW_API_KEY=your-iflow-api-key

# qodercli 配置（可选）
# QODERCLI_PATH=/usr/local/bin/qodercli
# QODERCLI_ARGS=

# --------------------------------------------
# Docker 远程连接配置（可选）
# --------------------------------------------
# 远程 Docker 主机地址
DOCKER_HOST=122.51.50.97

# Docker API 端口（默认 2375，TLS 通常是 2376）
DOCKER_PORT=2375

# Docker 认证信息（如果需要 HTTP Basic Auth）
DOCKER_USERNAME=admin
DOCKER_PASSWORD=admin

# SSH 连接配置（推荐使用 SSH 方式）
DOCKER_SSH_HOST=122.51.50.97
DOCKER_SSH_PORT=22
DOCKER_SSH_USERNAME=root
DOCKER_SSH_PASSWORD=Wj1314HHXXttxs
# 或使用私钥（推荐）
# DOCKER_SSH_KEY_PATH=/path/to/private/key

# --------------------------------------------
# 可选配置
# --------------------------------------------
# WebSocket 端口（如果不设置，将使用 HTTP 服务器）
# WS_PORT=3002
