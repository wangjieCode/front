{
  "name": "web-frontend-intern-assistant-backend",
  "version": "1.0.0",
  "description": "Web 前端实习生助手系统 - 后端服务",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node --import tsx scripts/build.ts",
    "start": "node --import tsx src/index.ts",
    "start:worker": "node --import tsx src/worker.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify:neovate": "node scripts/verify-neovate-sdk.mjs",
    "verify:vision": "node scripts/verify-vision-model.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:test": "tsx src/db/init.ts",
    "init:projects": "tsx scripts/init-projects.ts",
    "init:projects:dry-run": "tsx scripts/init-projects.ts --dry-run",
    "reinit:project": "tsx scripts/reinit-project.ts",
    "test:path-utils": "tsx scripts/test-path-utils.ts",
    "test:new-prompt": "node scripts/test-new-prompt.mjs"
  },
  "keywords": [
    "frontend",
    "assistant",
    "ai",
    "ssh",
    "gitlab"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@bull-board/api": "^6.16.4",
    "@bull-board/express": "^6.16.4",
    "@neovate/code": "^0.27.1",
    "@front/shared": "workspace:*",
    "bullmq": "^5.67.2",
    "dayjs": "^1.11.19",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.7",
    "express": "^4.18.2",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.4",
    "postgres": "^3.4.7",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "uuidv7": "^1.1.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.31.7",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
