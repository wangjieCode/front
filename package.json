{
  "name": "front-intern-deploy",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "deploy:server": "zx ./deploy.mjs",
    "logs": "zx ./deploy.mjs logs",
    "logs:view": "zx ./deploy.mjs logs:view",
    "logs:error": "zx ./deploy.mjs logs:error",
    "logs:all": "zx ./deploy.mjs logs all",
    "status": "zx ./deploy.mjs status",
    "restart": "zx ./deploy.mjs restart",
    "restart:worker": "zx ./deploy.mjs restart:worker",
    "restart:all": "zx ./deploy.mjs restart:all",
    "remote:init": "zx ./deploy.mjs remote:init",
    "remote:init:dry-run": "zx ./deploy.mjs remote:init:dry-run",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "zx": "^8.1.0"
  }
}
